# RunPod Network Storage Configuration
# Volume: moola
# Region: EU-RO-1

# S3-Compatible Endpoint
export RUNPOD_VOLUME_NAME="moola"
export RUNPOD_VOLUME_ID="22uv11rdjk"
export RUNPOD_S3_ENDPOINT="https://s3api-eu-ro-1.runpod.io"
export RUNPOD_S3_REGION="eu-ro-1"
export RUNPOD_S3_BUCKET="s3://22uv11rdjk"

# AWS S3 CLI Configuration
# Usage: aws s3 ls --region $RUNPOD_S3_REGION --endpoint-url $RUNPOD_S3_ENDPOINT $RUNPOD_S3_BUCKET/
export AWS_REGION="eu-ro-1"
export AWS_ENDPOINT_URL="https://s3api-eu-ro-1.runpod.io"

# Note: You'll need to set AWS credentials separately:
# export AWS_ACCESS_KEY_ID="your-runpod-access-key"
# export AWS_SECRET_ACCESS_KEY="your-runpod-secret-key"
# Get these from: https://www.runpod.io/console/user/settings (API Keys section)
